# Optional credentials — every tool works without them, but tokens raise rate
# limits (GitHub) or switch mock data to live data (X).

# GitHub personal access token (classic or fine-grained, no scopes needed for
# public search). Raises the Search API limit from 10 to 30 requests/minute.
GITHUB_TOKEN=

# X (Twitter) API v2 bearer token. When set, get_x_ai_trends fetches live
# tweets from the recent-search endpoint; when empty it serves curated mock
# data with the same response shape.
X_BEARER_TOKEN=

# Hugging Face token (optional; public model listings work anonymously).
HF_TOKEN=
